        rgbGen lightingdiffuse
		blendFunc blend
        tcmod rotate 999
	}
    {
		clampmap models/players/slash/yurikoskate.tga
        rgbGen lightingdiffuse
		blendFunc blend
        tcMod stretch sin .9 0 0 0
        tcmod rotate 20
	}
}

