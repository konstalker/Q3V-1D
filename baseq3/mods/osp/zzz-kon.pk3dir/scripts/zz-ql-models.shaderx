// Player Model Icons - High Quality (Fixed Alpha)
// ===============================================

models/players/anarki/icon_pm
{
    nopicmip
    nomipmaps
    {
        clampmap models/players/anarki/icon_pm.tga
        blendFunc GL_SRC_ALPHA GL_ONE_MINUS_SRC_ALPHA
        rgbGen identity
        alphaGen identity
        alphaFunc GT0
        depthWrite
    }
}

