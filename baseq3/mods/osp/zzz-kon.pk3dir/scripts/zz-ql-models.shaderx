        rgbGen lightingdiffuse
    }
    {
        map models/players/crash/crash.tga
		rgbGen lightingdiffuse
    }
}

models/players/crash/crash_f
{
   	q3map_surfacelight 10
	nopicmip
	{
	animmap 18 models/players/doom/TV/2.jpg models/players/doom/TV/3.jpg models/players/doom/TV/4.jpg models/players/doom/TV/5.jpg models/players/doom/TV/6.jpg models/players/doom/TV/7.jpg models/players/doom/TV/8.jpg models/players/doom/TV/9.jpg models/players/doom/TV/10.jpg models/players/doom/TV/11.jpg models/players/doom/TV/13.jpg models/players/doom/TV/14.jpg models/players/doom/TV/15.jpg models/players/doom/TV/16.jpg  models/players/doom/TV/17.jpg models/players/doom/TV/18.jpg models/players/doom/TV/19.jpg models/players/doom/TV/20.jpg models/players/doom/TV/21.jpg models/players/doom/TV/22.jpg models/players/doom/TV/23.jpg models/players/doom/TV/24.jpg models/players/doom/TV/1.jpg
	tcMod scale 1 1.3
	tcMod stretch sin 1 .035 0.5 0.4
	rgbGen identity
	//blendfunc add
	}
	{
	map models/players/crash/crash_f.tga
	blendFunc GL_ONE GL_ONE
	rgbGen lightingdiffuse
	}
	{
	map models/players/doom/glow2.jpg
	blendFunc GL_ONE GL_ONE
	tcMod scroll 3 0.65
    }
}

