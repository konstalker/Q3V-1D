models/players/bones/xray
{
	novlcollapse
	nopicmip   
    cull disable
    {
		map models/players/bones/xray.tga
        blendfunc add
		rgbGen lightingdiffuse
    }
    {
        map models/mapobjects/bitch/hologirl2.tga
        tcMod scroll -6 -.2
        tcgen environment
		blendFunc GL_ONE GL_ONE
		rgbGen identity
	}    
}

